{
  "manifest_version": 3,
  "name": "Page Highlighter (Starter)",
  "version": "2.0.0",
  "description": "Highlight any word on the current page from the popup or context menu.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Highlighter"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
